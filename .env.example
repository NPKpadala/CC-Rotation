# ─── Database (PostgreSQL 16+) ────────────────────────────────────────────────
# Local Windows / Linux:
#   postgresql://USER:PASSWORD@localhost:5432/cc_rotation_ledger?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cc_rotation_ledger?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 64
# Or PowerShell:  [Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Maximum 256}))
AUTH_SECRET="REPLACE_ME_WITH_A_64_CHAR_RANDOM_STRING_FROM_OPENSSL_OR_POWERSHELL"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ─── ADDED v1.2: Encryption key for full card numbers stored at rest ──────────
# Required as of v1.2. Used for AES-256-GCM of full PANs in the cards table
# and fraud table. MUST be a 64-character hex string (32 bytes).
#
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# CRITICAL: BACK UP THIS KEY SEPARATELY FROM YOUR DATABASE.
# If lost, all encrypted card numbers become unrecoverable.
ENCRYPTION_KEY="REPLACE_ME_WITH_64_HEX_CHARS_FROM_NODE_CRYPTO_RANDOMBYTES"

# ─── File storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_MB="5"

# ─── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="CC Rotation Ledger"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NODE_ENV="development"
